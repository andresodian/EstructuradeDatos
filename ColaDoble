int main() {
    DDQueue lista;
    int opcion;
    DATA_TYPE dato;

    do {
        cout << "\n--- MENU COLA DOBLE ---" << endl;
        cout << "1. Poner al FRENTE" << endl;
        cout << "2. Poner al FINAL" << endl;
        cout << "3. Sacar del FRENTE" << endl;
        cout << "4. Sacar del FINAL" << endl;
        cout << "5. Mostrar Cola" << endl;
        cout << "6. Salir" << endl;
        cout << "Seleccione: ";
        cin >> opcion;

        switch (opcion) {
        case 1:
            cout << "Caracter: "; cin >> dato;
            lista.ponerFrente(dato);
            break;
        case 2:
            cout << "Caracter: "; cin >> dato;
            lista.ponerFinal(dato);
            break;
        case 3:
            dato = lista.sacarFrente();
            if (dato != -1) cout << "Extraido: " << dato << endl;
            break;
        case 4:
            dato = lista.sacarFinal();
            if (dato != -1) cout << "Extraido: " << dato << endl;
            break;
        case 5:
            lista.mostrar();
            break;
        }
    } while (opcion != 6);

    return 0;
}
