//DDQueue.cpp
#include "DDQueue.h"
#include <iostream>

using namespace std;

DDQueue::DDQueue() {
    frente = NULL;
    final = NULL;
    items = 0;
}

DDQueue::~DDQueue() {
    while (!estaVacia()) {
        sacarFrente();
    }
}

bool DDQueue::estaVacia() {
    return items == 0;
}

void DDQueue::ponerFrente(DATA_TYPE valor) {
    Nodo* nuevo = new Nodo(valor);
    if (estaVacia()) {
        frente = final = nuevo;
    }
    else {
        nuevo->next = frente;
        frente->prev = nuevo;
        frente = nuevo;
    }
    items++;
}

void DDQueue::ponerFinal(DATA_TYPE valor) {
    Nodo* nuevo = new Nodo(valor);
    if (estaVacia()) {
        frente = final = nuevo;
    }
    else {
        final->next = nuevo;
        nuevo->prev = final;
        final = nuevo;
    }
    items++;
}

DATA_TYPE DDQueue::sacarFrente() {
    if (estaVacia()) return -1;

    DATA_TYPE valor = frente->data;
    Nodo* temp = frente;
    frente = frente->next;

    if (frente) frente->prev = NULL;
    else final = NULL;

    delete temp;
    items--;
    return valor;
}

DATA_TYPE DDQueue::sacarFinal() {
    if (estaVacia()) return -1;

    DATA_TYPE valor = final->data;
    Nodo* temp = final;
    final = final->prev;

    if (final) final->next = NULL;
    else frente = NULL;

    delete temp;
    items--;
    return valor;
}

void DDQueue::mostrar() {
    if (estaVacia()) {
        cout << "Lista vacia." << endl;
        return;
    }
    Nodo* aux = frente;
    while (aux) {
        cout << aux->data << " ";
        aux = aux->next;
    }
    cout << endl;
}
